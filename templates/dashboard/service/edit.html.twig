{% extends 'dashboard/base.html.twig' %}

{% block title %}Edit Service - {{ service.name }}{% endblock %}

{% block dashboard_content %}  
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Edit Service</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_service_index') }}">Services</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_service_show', {'id': service.id}) }}">{{ service.name }}</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="{{ path('app_service_show', {'id': service.id}) }}" class="btn btn-outline-secondary me-2">
            <i class="bi bi-eye me-1"></i> View
        </a>
        <a href="{{ path('app_service_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Edit Service Information</h5>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row">
                    <!-- Basic Information -->
                    <div class="col-md-8 mb-3">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.category) }}
                        {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.price) }}
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.duration) }}
                        <div class="input-group">
                            {{ form_widget(form.duration, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">minutes</span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.features) }}
                    {{ form_widget(form.features, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                </div>

                <!-- Requirements -->
                <div class="row">
                    <div class="col-12">
                        <h6 class="border-bottom pb-2 mb-3">Requirements & Restrictions</h6>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="form-check form-switch">
                            {{ form_widget(form.requiresSpecialEquipment, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(form.requiresSpecialEquipment, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="form-check form-switch">
                            {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(form.isActive, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>
                    </div>
                    <div class="col-12 mb-3">
                        {{ form_label(form.specialInstructions) }}
                        {{ form_widget(form.specialInstructions, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                    </div>
                </div>

                <!-- Pet Restrictions -->
                <div class="row">
                    <div class="col-12 mb-3">
                        <h6 class="border-bottom pb-2 mb-3">Pet Restrictions</h6>
                    </div>
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.weightLimit) }}
                        <div class="input-group">
                            {{ form_widget(form.weightLimit, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">kg</span>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.minPetAge) }}
                        <div class="input-group">
                            {{ form_widget(form.minPetAge, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">years</span>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        {{ form_label(form.maxPetAge) }}
                        <div class="input-group">
                            {{ form_widget(form.maxPetAge, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">years</span>
                        </div>
                    </div>
                </div>

                <!-- Image -->
                <div class="mb-3">
                    {{ form_label(form.image) }}
                    {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                    {% if service.image %}
                    <div class="mt-2">
                        <img src="{{ service.image }}" alt="Current Image" class="img-thumbnail" style="max-height: 150px;">
                    </div>
                    {% endif %}
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="{{ path('app_service_show', {'id': service.id}) }}" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Save Changes
                    </button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}