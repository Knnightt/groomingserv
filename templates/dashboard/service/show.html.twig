{% extends 'dashboard/base.html.twig' %}

{% block title %}Service Details - {{ service.name }}{% endblock %}

{% block dashboard_content %}  
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Service Details</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_service_index') }}">Services</a></li>
                <li class="breadcrumb-item active">{{ service.name }}</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="{{ path('app_service_edit', {'id': service.id}) }}" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a href="{{ path('app_service_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <!-- Service Details -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Service Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center mb-4 mb-md-0">
                        {% if service.image %}
                            <img src="{{ service.image }}" alt="{{ service.name }}" class="img-fluid rounded" style="max-height: 200px;">
                        {% else %}
                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-scissors text-muted" style="font-size: 4rem;"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-8">
                        <h3>{{ service.name }}</h3>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-{{ service.category == 'Premium' ? 'warning' : service.category == 'Ultimate' ? 'danger' : 'info' }}">
                                {{ service.category }}
                            </span>
                            {% if service.isActive %}
                                <span class="badge bg-success">Active</span>
                            {% else %}
                                <span class="badge bg-danger">Inactive</span>
                            {% endif %}
                            {% if service.requiresSpecialEquipment %}
                                <span class="badge bg-warning">Special Equipment</span>
                            {% endif %}
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Price:</strong> ${{ service.price|number_format(2) }}
                            </div>
                            <div class="col-md-6">
                                <strong>Duration:</strong> {{ service.duration }} minutes
                            </div>
                        </div>
                        
                        {% if service.description %}
                        <div class="mb-3">
                            <strong>Description:</strong>
                            <p class="text-muted">{{ service.description }}</p>
                        </div>
                        {% endif %}
                        
                        {% if service.features %}
                        <div class="mb-3">
                            <strong>Features:</strong>
                            <p class="text-muted">{{ service.features }}</p>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Requirements & Restrictions -->
        <div class="row">
            {% if service.specialInstructions or service.requiresSpecialEquipment %}
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h6 class="card-title mb-0">Requirements</h6>
                    </div>
                    <div class="card-body">
                        {% if service.requiresSpecialEquipment %}
                            <div class="alert alert-warning mb-3">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                Requires special equipment
                            </div>
                        {% endif %}
                        {% if service.specialInstructions %}
                            <strong>Special Instructions:</strong>
                            <p class="text-muted">{{ service.specialInstructions }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            {% if service.weightLimit or service.minPetAge or service.maxPetAge %}
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h6 class="card-title mb-0">Pet Restrictions</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            {% if service.weightLimit %}
                            <div class="col-12 mb-2">
                                <strong>Weight Limit:</strong> {{ service.weightLimit }} kg
                            </div>
                            {% endif %}
                            {% if service.minPetAge %}
                            <div class="col-12 mb-2">
                                <strong>Minimum Age:</strong> {{ service.minPetAge }} years
                            </div>
                            {% endif %}
                            {% if service.maxPetAge %}
                            <div class="col-12">
                                <strong>Maximum Age:</strong> {{ service.maxPetAge }} years
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Sidebar Stats -->
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="card-title mb-0">Service Statistics</h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Total Appointments</span>
                        <span class="badge bg-primary rounded-pill">{{ appointments_count }}</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Revenue Generated</span>
                        <span class="badge bg-success rounded-pill">${{ total_revenue|number_format(2) }}</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>This Month</span>
                        <span class="badge bg-info rounded-pill">{{ monthly_appointments }}</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Average Rating</span>
                        <span class="badge bg-warning rounded-pill">4.5/5</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_service_edit', {'id': service.id}) }}" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-2"></i> Edit Service
                    </a>
                    <a href="{{ path('app_scheduling_new', {'service_id': service.id}) }}" class="btn btn-outline-success">
                        <i class="bi bi-calendar-plus me-2"></i> Schedule Appointment
                    </a>
                    <button type="button" class="btn btn-outline-{{ service.isActive ? 'danger' : 'success' }}" 
                            onclick="toggleServiceStatus({{ service.id }}, {{ service.isActive ? 'false' : 'true' }})">
                        <i class="bi bi-power me-2"></i>
                        {{ service.isActive ? 'Deactivate' : 'Activate' }} Service
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Appointments -->
<div class="card mt-4">
    <div class="card-header">
        <h5 class="card-title mb-0">Recent Appointments</h5>
    </div>
    <div class="card-body">
        {% if recent_appointments|length > 0 %}
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Pet</th>
                        <th>Status</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    {% for appointment in recent_appointments %}
                    <tr>
                        <td>{{ appointment.startAt|date('M d, Y H:i') }}</td>
                        <td>{{ appointment.customer.displayName }}</td>
                        <td>{{ appointment.pet.name }}</td>
                        <td>
                            <span class="badge bg-{{ appointment.status == 'Completed' ? 'success' : appointment.status == 'Confirmed' ? 'info' : 'warning' }}">
                                {{ appointment.status }}
                            </span>
                        </td>
                        <td>${{ appointment.amount|number_format(2) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="text-center py-4">
            <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-2">No appointments for this service yet</p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function toggleServiceStatus(serviceId, newStatus) {
            if (confirm('Are you sure you want to ' + (newStatus ? 'activate' : 'deactivate') + ' this service?')) {
                fetch('/dashboard/service/' + serviceId + '/toggle-status', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': '{{ csrf_token("toggle_service") }}'
                    },
                    body: JSON.stringify({ isActive: newStatus })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                });
            }
        }
    </script>
{% endblock %}