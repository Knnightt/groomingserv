{% extends 'dashboard/base.html.twig' %}

{% block dashboard_title %}Appointment #{{ appointment.id }}{% endblock %}

{% block dashboard_content %}  
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Appointment #{{ appointment.id }}</h1>
                <div>
                    <a href="{{ path('app_appointment_edit', {'id': appointment.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>Edit
                    </a>
                    <a href="{{ path('app_appointment_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Appointment Details</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase small fw-bold mb-2">Pet</h6>
                            <p class="mb-3">
                                <a href="{{ path('app_pet_show', {'id': appointment.pet.id}) }}">{{ appointment.pet.name }}</a>
                                <br>
                                <small class="text-muted">{{ appointment.pet.species }} - {{ appointment.pet.breed }}</small>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase small fw-bold mb-2">Service</h6>
                            <p class="mb-3">
                                {{ appointment.service.name }}
                                <br>
                                <small class="text-muted">${{ appointment.service.price|number_format(2) }}</small>
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase small fw-bold mb-2">Start Time</h6>
                            <p class="mb-3">{{ appointment.startTime|date('M d, Y H:i') }}</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase small fw-bold mb-2">End Time</h6>
                            <p class="mb-3">{{ appointment.endTime|date('M d, Y H:i') }}</p>
                        </div>
                    </div>

                    {% if appointment.staff %}
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">Assigned Staff</h6>
                        <p class="mb-3">{{ appointment.staff.name }}</p>
                    {% endif %}

                    {% if appointment.notes %}
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">Notes</h6>
                        <p class="mb-0">{{ appointment.notes }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Pricing</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tr>
                            <td>Service Price:</td>
                            <td class="text-end">${{ appointment.price|number_format(2) }}</td>
                        </tr>
                        {% if appointment.discount > 0 %}
                            <tr class="text-success">
                                <td>Discount:</td>
                                <td class="text-end">-${{ appointment.discount|number_format(2) }}</td>
                            </tr>
                        {% endif %}
                        {% if appointment.tax > 0 %}
                            <tr>
                                <td>Tax:</td>
                                <td class="text-end">+${{ appointment.tax|number_format(2) }}</td>
                            </tr>
                        {% endif %}
                        <tr class="fw-bold border-top">
                            <td>Total:</td>
                            <td class="text-end text-success">${{ (appointment.price - appointment.discount + appointment.tax)|number_format(2) }}</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Status</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong>Current Status:</strong></p>
                    <p class="mb-3">
                        {% if appointment.status == 'completed' %}
                            <span class="badge bg-success px-3 py-2">Completed</span>
                        {% elseif appointment.status == 'pending' %}
                            <span class="badge bg-warning text-dark px-3 py-2">Pending</span>
                        {% elseif appointment.status == 'cancelled' %}
                            <span class="badge bg-danger px-3 py-2">Cancelled</span>
                        {% else %}
                            <span class="badge bg-info px-3 py-2">{{ appointment.status|capitalize }}</span>
                        {% endif %}
                    </p>
                    <p class="mb-0">
                        <strong>Created:</strong><br>
                        <small class="text-muted">{{ appointment.createdAt|date('M d, Y H:i') }}</small>
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Customer</h5>
                </div>
                <div class="card-body">
                    {% if appointment.pet.user %}
                        <p class="mb-2"><strong>Name:</strong></p>
                        <p class="text-muted mb-3">{{ appointment.pet.user.userProfile.firstName or 'N/A' }} {{ appointment.pet.user.userProfile.lastName or 'N/A' }}</p>

                        <p class="mb-2"><strong>Email:</strong></p>
                        <p class="text-muted mb-3">{{ appointment.pet.user.email }}</p>

                        <a href="{{ path('app_user_management_show', {'id': appointment.pet.user.id}) }}" class="btn btn-sm btn-primary w-100">
                            <i class="bi bi-person me-2"></i>View Customer
                        </a>
                    {% else %}
                        <p class="text-muted">No customer assigned</p>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('app_appointment_edit', {'id': appointment.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>Edit
                    </a>
                    <a href="{{ path('app_appointment_index') }}" class="btn btn-secondary">
                        <i class="bi bi-list me-2"></i>View All
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
