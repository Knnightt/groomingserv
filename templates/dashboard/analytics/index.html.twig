{% extends 'dashboard/base.html.twig' %}

{% block title %}Analytics Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Remove the encore_entry_exists check -->
    {# {{ encore_entry_link_tags('dashboard-analytics') }} #}
{% endblock %}

{% block dashboard_content %}
<div class="dashboard-analytics">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2">Analytics Dashboard</h1>
            <p class="text-muted mb-0">Real-time business performance overview</p>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm dropdown-range" data-range-dropdown style="width: 150px;">
                <option value="30" selected>Last 30 Days</option>
                <option value="7">Last 7 Days</option>
                <option value="90">Last 90 Days</option>
                <option value="365">Last Year</option>
            </select>
            <button id="refreshData" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-primary stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">Total Revenue</h6>
                            <h3 class="mb-0">${{ total_revenue|number_format(2) }}</h3>
                            <small class="text-{{ revenue_change >= 0 ? 'success' : 'danger' }}">
                                <i class="bi bi-arrow-{{ revenue_change >= 0 ? 'up' : 'down' }} me-1"></i>
                                {{ revenue_change|abs|number_format(1) }}% vs last month
                            </small>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-currency-dollar text-primary fs-1"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-success stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">Today's Revenue</h6>
                            <h3 class="mb-0">${{ today_revenue|number_format(2) }}</h3>
                            <small class="text-muted">
                                {{ todays_completed_count }} completed today
                            </small>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-calendar-day text-success fs-1"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-warning stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">Total Appointments</h6>
                            <h3 class="mb-0">{{ total_appointments }}</h3>
                            <small class="text-warning">
                                <i class="bi bi-clock-history me-1"></i>
                                {{ pending_appointments }} pending
                            </small>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-calendar-check text-warning fs-1"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-info stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">Registered Users</h6>
                            <h3 class="mb-0">{{ total_users }}</h3>
                            <small class="text-muted">
                                {{ total_pets }} pets registered
                            </small>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-people text-info fs-1"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Tables -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Today's Appointments</h5>
                    <span class="badge bg-secondary">{{ todays_appointments|length }}</span>
                </div>
                <div class="card-body table-container">
                    <div class="table-responsive">
                        <table class="table table-sm small-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Customer</th>
                                    <th>Pet</th>
                                    <th>Service</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for appointment in todays_appointments %}
                                <tr>
                                    <td>{{ appointment.startAt|date('H:i') }}</td>
                                    <td>
                                        {# Use displayName #}
                                        {{ appointment.customer.displayName }}
                                    </td>
                                    <td>{{ appointment.pet.name ?? 'N/A' }}</td>
                                    <td><span class="badge bg-light text-dark">{{ appointment.service.name|slice(0, 15) }}{{ appointment.service.name|length > 15 ? '...' : '' }}</span></td>
                                    <td>
                                        {% set status_color = 'secondary' %}
                                        {% if appointment.status == 'Confirmed' %}{% set status_color = 'success' %}{% endif %}
                                        {% if appointment.status == 'Pending' %}{% set status_color = 'warning' %}{% endif %}
                                        {% if appointment.status == 'Completed' %}{% set status_color = 'info' %}{% endif %}
                                        {% if appointment.status == 'Cancelled' %}{% set status_color = 'danger' %}{% endif %}
                                        
                                        <span class="badge bg-{{ status_color }}">
                                            {{ appointment.status }}
                                        </span>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted">No appointments today</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Recent Activity</h5>
                    {% if 'app_activity_log_index' in app.request.attributes.get('_route') %}
                        <a href="{{ path('app_activity_log_index') }}" class="btn btn-sm btn-outline-primary">View All</a>
                    {% endif %}
                </div>
                <div class="card-body table-container">
                {% if recent_activities is defined and recent_activities|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-sm small-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for activity in recent_activities|slice(0, 5) %}
                                <tr>
                                    <td>{{ activity.time }}</td> {# CHANGED FROM activity.createdAt #}
                                    <td>{{ activity.user }}</td>
                                    <td><span class="badge bg-info">{{ activity.action }}</span></td>
                                    <td>
                                        {% if activity.service and activity.pet %}
                                            {{ activity.action }} for {{ activity.pet }} ({{ activity.service }})
                                        {% else %}
                                            {{ activity.action }}
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-activity fs-1 mb-3"></i>
                        <p>No recent activity to display</p>
                    </div>
                {% endif %}
            </div>
            </div>
        </div>
    </div>

    <!-- Recent Appointments Table -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Recent Appointments</h5>
                    <a href="{{ path('app_scheduling_index') }}" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm small-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Customer</th>
                                    <th>Pet</th>
                                    <th>Service</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for appointment in recent_appointments %}
                                <tr>
                                    <td>{{ appointment.startAt|date('M d, Y') }}</td>
                                    <td>
                                        {# Use displayName #}
                                        {{ appointment.customer.displayName }}
                                    </td>
                                    <td>{{ appointment.pet.name ?? 'N/A' }}</td>
                                    <td>{{ appointment.service.name|slice(0, 20) }}{{ appointment.service.name|length > 20 ? '...' : '' }}</td>
                                    <td>${{ appointment.amount|number_format(2) }}</td>
                                    <td>
                                        {% set status_color = 'secondary' %}
                                        {% if appointment.status == 'Confirmed' %}{% set status_color = 'success' %}{% endif %}
                                        {% if appointment.status == 'Pending' %}{% set status_color = 'warning' %}{% endif %}
                                        {% if appointment.status == 'Completed' %}{% set status_color = 'info' %}{% endif %}
                                        {% if appointment.status == 'Cancelled' %}{% set status_color = 'danger' %}{% endif %}
                                        
                                        <span class="badge bg-{{ status_color }}">
                                            {{ appointment.status }}
                                        </span>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted">No recent appointments</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Export Section -->
    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">Export Reports</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <button class="btn btn-outline-primary w-100 export-btn" data-export="revenue">
                        <i class="bi bi-file-earmark-pdf me-2"></i> Revenue Report
                    </button>
                </div>
                <div class="col-md-3 mb-3">
                    <button class="btn btn-outline-success w-100 export-btn" data-export="appointments">
                        <i class="bi bi-file-earmark-excel me-2"></i> Appointments Report
                    </button>
                </div>
                <div class="col-md-3 mb-3">
                    <button class="btn btn-outline-warning w-100 export-btn" data-export="customers">
                        <i class="bi bi-file-earmark-text me-2"></i> Customer Report
                    </button>
                </div>
                <div class="col-md-3 mb-3">
                    <button class="btn btn-outline-info w-100 export-btn" data-export="all">
                        <i class="bi bi-file-earmark-bar-graph me-2"></i> Full Report
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    {# Remove the encore_entry_exists check #}
    {# {{ encore_entry_script_tags('dashboard-analytics') }} #}
    
    <script>
        // Simple refresh functionality
        document.getElementById('refreshData')?.addEventListener('click', function() {
            this.classList.add('rotate');
            setTimeout(() => {
                window.location.reload();
            }, 500);
        });

        // Export button functionality
        document.querySelectorAll('.export-btn').forEach(button => {
            button.addEventListener('click', function() {
                const reportType = this.dataset.export;
                alert(`Exporting ${reportType} report... (Functionality to be implemented)`);
            });
        });
    </script>
{% endblock %}