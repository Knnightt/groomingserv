<div class="list-group activity-list">
    {% for activity in activities|default([]) %}
        <div class="list-group-item">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <h6 class="mb-1">{{ activity.user }}</h6>
                    <p class="mb-1 text-muted">{{ activity.action }}</p>
                    {% if activity.pet %}
                        <small class="text-muted">
                            <i class="bi bi-paw me-1"></i>{{ activity.pet }}
                            {% if activity.service %}
                                • {{ activity.service }}
                            {% endif %}
                            {% if activity.amount %}
                                • ${{ activity.amount|number_format(2) }}
                            {% endif %}
                        </small>
                    {% endif %}
                </div>
                <small class="text-muted text-nowrap ms-2">{{ activity.time }}</small>
            </div>
        </div>
    {% else %}
        <div class="list-group-item text-center text-muted py-4">
            <i class="bi bi-activity fs-3 mb-2 d-block"></i>
            No recent activity
        </div>
    {% endfor %}
</div>