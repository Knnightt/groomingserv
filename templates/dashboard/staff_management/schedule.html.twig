{% extends 'dashboard/base.html.twig' %}

{% block title %}Staff Schedule - {{ staff.displayName }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css">
    {{ parent() }}
{% endblock %}

{% block dashboard_content %}  
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Staff Schedule</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_staff_management_index') }}">Staff</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_staff_management_show', {'id': staff.id}) }}">{{ staff.displayName }}</a></li>
                <li class="breadcrumb-item active">Schedule</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="{{ path('app_staff_management_show', {'id': staff.id}) }}" class="btn btn-outline-secondary me-2">
            <i class="bi bi-arrow-left me-1"></i> Back to Profile
        </a>
        <a href="{{ path('app_scheduling_new', {'staff_id': staff.id}) }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Schedule Appointment
        </a>
    </div>
</div>

<div class="row">
    <!-- Schedule Calendar -->
    <div class="col-lg-9">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Appointment Calendar</h5>
            </div>
            <div class="card-body">
                <div id="calendar"></div>
            </div>
        </div>
    </div>

    <!-- Staff Info & Quick Actions -->
    <div class="col-lg-3">
        <div class="card mb-4">
            <div class="card-body text-center">
                {% if staff.photo %}
                    <img src="{{ staff.photo }}" alt="{{ staff.displayName }}" class="rounded-circle mb-3" style="width: 100px; height: 100px; object-fit: cover;">
                {% else %}
                    <div class="avatar bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 100px; height: 100px;">
                        <i class="bi bi-person text-muted" style="font-size: 3rem;"></i>
                    </div>
                {% endif %}
                <h5>{{ staff.displayName }}</h5>
                <p class="text-muted">{{ staff.getRoleLabel() }}</p>
                
                <div class="list-group list-group-flush">
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Status:</span>
                            <strong>
                                <span class="badge bg-{{ staff.isActive() ? 'success' : 'danger' }}">
                                    {{ staff.employmentStatus }}
                                </span>
                            </strong>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Working Days:</span>
                            <strong>{{ staff.workingDays|length }}</strong>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Working Hours:</span>
                            <strong>{{ staff.getWorkingHours() }}</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Today's Appointments -->
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="card-title mb-0">Today's Appointments</h6>
            </div>
            <div class="card-body">
                {% if todays_appointments|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for appointment in todays_appointments %}
                        <a href="{{ path('app_scheduling_show', {'id': appointment.id}) }}" class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>{{ appointment.pet.name }}</strong><br>
                                    <small class="text-muted">{{ appointment.service.name }}</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-{{ appointment.status == 'Completed' ? 'success' : appointment.status == 'Confirmed' ? 'info' : 'warning' }}">
                                        {{ appointment.status }}
                                    </span><br>
                                    <small>{{ appointment.startAt|date('h:i A') }}</small>
                                </div>
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-3">
                        <i class="bi bi-calendar-check text-muted"></i>
                        <p class="text-muted mt-2 mb-0">No appointments today</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Schedule Settings -->
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">Schedule Settings</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_staff_management_edit', {'id': staff.id}) }}#working-schedule" class="btn btn-outline-warning">
                        <i class="bi bi-gear me-2"></i> Edit Working Hours
                    </a>
                    <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#timeOffModal">
                        <i class="bi bi-calendar-x me-2"></i> Request Time Off
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Time Off Modal -->
<div class="modal fade" id="timeOffModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Time Off</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="timeOffForm">
                    <div class="mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" class="form-control" name="start_date" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" class="form-control" name="end_date" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <textarea class="form-control" name="reason" rows="3" required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="requestTimeOff()">Submit Request</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'timeGridWeek,timeGridDay,listWeek'
                },
                events: '/dashboard/staff/{{ staff.id }}/schedule-events',
                eventClick: function(info) {
                    window.location.href = '/dashboard/scheduling/' + info.event.id + '/show';
                },
                businessHours: {
                    daysOfWeek: [{% for day in staff.workingDays %}{{ getDayNumber(day) }}{% if not loop.last %},{% endif %}{% endfor %}],
                    startTime: '{{ staff.startTime ? staff.startTime|date("H:i") : "09:00" }}',
                    endTime: '{{ staff.endTime ? staff.endTime|date("H:i") : "18:00" }}'
                },
                slotMinTime: '08:00:00',
                slotMaxTime: '20:00:00',
                height: 'auto',
                navLinks: true,
                editable: false,
                selectable: false
            });
            calendar.render();
        });

        function requestTimeOff() {
            const form = document.getElementById('timeOffForm');
            const formData = new FormData(form);
            
            fetch('/dashboard/staff/{{ staff.id }}/request-time-off', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-CSRF-Token': '{{ csrf_token("time_off") }}'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Time off request submitted!');
                    $('#timeOffModal').modal('hide');
                    form.reset();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
    </script>
{% endblock %}