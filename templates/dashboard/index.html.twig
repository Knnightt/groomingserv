{% extends 'dashboard/base.html.twig' %}

{% block dashboard_title %}Dashboard Overview{% endblock %}

{% block dashboard_content %}
<div class="container-fluid px-4 dashboard-container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 dashboard-header">
        <div>
            <h1 class="h3 mb-1">Welcome back, {{ app.user.displayName }}! 👋</h1>
            <p class="text-muted mb-0">Here's what's happening with your account today.</p>
        </div>
        <div class="d-flex align-items-center">
            <span class="badge bg-primary fs-6 me-3 px-3 py-2 dashboard-date-badge">
                <i class="bi bi-calendar-check me-1"></i>
                {{ "now"|date("l, F j, Y") }}
            </span>
            <button class="btn btn-outline-primary dashboard-refresh-btn" id="refreshBtn">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4 dashboard-stats-row">
        {% if is_granted('ROLE_ADMIN') %}
            <!-- Admin Stats -->
            <div class="col-xl-3 col-md-6">
                <div class="card card-stat border-start border-primary">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Total Users</h6>
                                <h2 class="mb-0">{{ stats.total_users|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-primary-light">
                                <i class="bi bi-people-fill text-primary fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_user_management_index') }}" class="text-decoration-none small stat-link">
                                View all users <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card card-stat border-start border-success">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Today's Revenue</h6>
                                <h2 class="mb-0">${{ stats.revenue_today|default('0.00') }}</h2>
                            </div>
                            <div class="stat-icon bg-success-light">
                                <i class="bi bi-currency-dollar text-success fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <span class="badge bg-success">+5.2%</span>
                            <span class="text-muted small ms-2">from yesterday</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card card-stat border-start border-info">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Active Appointments</h6>
                                <h2 class="mb-0">{{ stats.total_appointments|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-info-light">
                                <i class="bi bi-calendar-check text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="progress stat-progress">
                                <div class="progress-bar bg-info" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card card-stat border-start border-warning">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Staff Members</h6>
                                <h2 class="mb-0">{{ stats.total_staff|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-warning-light">
                                <i class="bi bi-person-badge text-warning fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_staff_management_index') }}" class="text-decoration-none small stat-link">
                                Manage staff <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        {% elseif is_granted('ROLE_MANAGER') %}
            <!-- Manager Stats -->
            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-primary">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Today's Revenue</h6>
                                <h2 class="mb-0">${{ stats.revenue_today|default('0.00') }}</h2>
                            </div>
                            <div class="stat-icon bg-primary-light">
                                <i class="bi bi-currency-dollar text-primary fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <span class="badge bg-success">+12.5%</span>
                            <span class="text-muted small ms-2">from last week</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-info">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Pending Appointments</h6>
                                <h2 class="mb-0">{{ stats.pending_appointments|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-info-light">
                                <i class="bi bi-clock text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_scheduling_index') }}" class="text-decoration-none small stat-link">
                                Review now <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-success">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Staff On Duty</h6>
                                <h2 class="mb-0">{{ stats.staff_on_duty|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-success-light">
                                <i class="bi bi-person-check text-success fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_staff_management_index') }}" class="text-decoration-none small stat-link">
                                View schedule <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        {% elseif is_granted('ROLE_STAFF') %}
            <!-- Staff Stats -->
            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-primary">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Today's Appointments</h6>
                                <h2 class="mb-0">{{ stats.my_appointments_today|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-primary-light">
                                <i class="bi bi-calendar-check text-primary fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="progress stat-progress">
                                <div class="progress-bar bg-primary" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-info">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Pet Records</h6>
                                <h2 class="mb-0">{{ stats.total_pets|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-info-light">
                                <i class="bi bi-heart-pulse text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_pet_index') }}" class="text-decoration-none small stat-link">
                                View all pets <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-warning">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Hours This Week</h6>
                                <h2 class="mb-0">{{ stats.hours_this_week|default('0') }}h</h2>
                            </div>
                            <div class="stat-icon bg-warning-light">
                                <i class="bi bi-stopwatch text-warning fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-clock me-1"></i>Clock In/Out
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        {% else %}
            <!-- User Stats -->
            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-primary">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">My Appointments</h6>
                                <h2 class="mb-0">{{ app.user.appointments|length }}</h2>
                            </div>
                            <div class="stat-icon bg-primary-light">
                                <i class="bi bi-calendar-check text-primary fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_scheduling_index') }}" class="btn btn-sm btn-primary">
                                View All
                            </a>
                            <a href="{{ path('app_scheduling_new') }}" class="btn btn-sm btn-outline-primary ms-2">
                                Book New
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-success">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">My Pets</h6>
                                <h2 class="mb-0">{{ app.user.pets|length }}</h2>
                            </div>
                            <div class="stat-icon bg-success-light">
                                <i class="bi bi-heart-pulse text-success fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_pet_index') }}" class="btn btn-sm btn-success">
                                Manage Pets
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card card-stat border-start border-info">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-uppercase text-muted mb-1">Upcoming</h6>
                                <h2 class="mb-0">{{ stats.upcoming_appointments|default(0) }}</h2>
                            </div>
                            <div class="stat-icon bg-info-light">
                                <i class="bi bi-bell text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="d-flex align-items-center">
                                <div class="flex-grow-1">
                                    <small class="text-muted">Next: {{ stats.next_appointment|default('No upcoming') }}</small>
                                </div>
                                <i class="bi bi-chevron-right text-info"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm quick-actions-card">
                <div class="card-header card-header-clean">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="col-xl-2 col-md-4 col-sm-6">
                                <a href="{{ path('app_user_management_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-primary-light">
                                            <i class="bi bi-people-fill text-primary fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">User Management</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-2 col-md-4 col-sm-6">
                                <a href="{{ path('app_staff_management_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-warning-light">
                                            <i class="bi bi-person-badge text-warning fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Staff Management</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-2 col-md-4 col-sm-6">
                                <a href="{{ path('app_scheduling_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-info-light">
                                            <i class="bi bi-calendar-check text-info fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Appointments</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-2 col-md-4 col-sm-6">
                                <a href="#" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-success-light">
                                            <i class="bi bi-graph-up text-success fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Reports</h6>
                                    </div>
                                </a>
                            </div>
                        {% elseif is_granted('ROLE_MANAGER') %}
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_scheduling_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-primary-light">
                                            <i class="bi bi-calendar-check text-primary fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Appointment Management</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_staff_management_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-info-light">
                                            <i class="bi bi-clock-history text-info fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Staff Scheduling</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_pet_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-success-light">
                                            <i class="bi bi-heart-pulse text-success fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Pet Records</h6>
                                    </div>
                                </a>
                            </div>
                        {% elseif is_granted('ROLE_STAFF') %}
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_scheduling_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-primary-light">
                                            <i class="bi bi-calendar-day text-primary fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Today's Schedule</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_pet_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-success-light">
                                            <i class="bi bi-heart-pulse text-success fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Pet Records</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="#" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-warning-light">
                                            <i class="bi bi-stopwatch text-warning fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Time Tracking</h6>
                                    </div>
                                </a>
                            </div>
                        {% else %}
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_scheduling_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-primary-light">
                                            <i class="bi bi-calendar-check text-primary fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">My Appointments</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_pet_index') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-success-light">
                                            <i class="bi bi-heart-pulse text-success fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">My Pets</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_scheduling_new') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-info-light">
                                            <i class="bi bi-plus-circle text-info fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Book Appointment</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-xl-3 col-md-6">
                                <a href="{{ path('app_settings_profile') }}" class="card text-center h-100 text-decoration-none quick-action-card">
                                    <div class="card-body py-4">
                                        <div class="quick-action-icon bg-warning-light">
                                            <i class="bi bi-gear text-warning fs-4"></i>
                                        </div>
                                        <h6 class="mb-0 quick-action-title">Settings</h6>
                                    </div>
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Appointments Table -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 appointments-card">
                <div class="card-header card-header-clean">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Recent Appointments</h5>
                        <a href="{{ path('app_scheduling_index') }}" class="btn btn-sm btn-outline-primary">
                            View All <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle dashboard-table" id="appointmentsTable">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Date & Time</th>
                                    <th>Pet</th>
                                    <th>Service</th>
                                    <th>Status</th>
                                    <th>Staff</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for appt in recent_appointments %}
                                    <tr>
                                        <td class="fw-semibold">#{{ appt.id }}</td>
                                        <td data-order="{{ appt.startAt ? appt.startAt|date('U') : 0 }}">
                                            <div class="d-flex flex-column">
                                                <span class="fw-medium">{{ appt.startAt ? appt.startAt|date('M j, Y') : '' }}</span>
                                                <small class="text-muted">{{ appt.startAt ? appt.startAt|date('g:i A') : '' }}</small>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0">
                                                    <div class="pet-icon">
                                                        <i class="bi bi-heart text-primary"></i>
                                                    </div>
                                                </div>
                                                <div class="flex-grow-1">
                                                    {{ appt.pet ? appt.pet.name : '' }}
                                                </div>
                                            </div>
                                        </td>
                                        <td>{{ appt.service ? appt.service.name : '' }}</td>
                                        <td>
                                            {% set status_class = {
                                                'confirmed': 'success',
                                                'pending': 'warning',
                                                'cancelled': 'danger',
                                                'completed': 'info'
                                            } %}
                                            <span class="badge status-badge bg-{{ status_class[appt.status]|default('secondary') }}">
                                                {{ appt.status|capitalize }}
                                            </span>
                                        </td>
                                        <td>
                                            {% if appt.assignedStaff and appt.assignedStaff.user %}
                                                {{ appt.assignedStaff.user.displayName }}
                                            {% else %}
                                                <span class="text-muted">Not assigned</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm action-buttons" role="group">
                                                <a href="{{ path('app_scheduling_show', {'id': appt.id}) }}" class="btn btn-outline-primary btn-icon" title="View">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="{{ path('app_scheduling_edit', {'id': appt.id}) }}" class="btn btn-outline-secondary btn-icon" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center py-5 empty-state">
                                            <div class="py-4">
                                                <i class="bi bi-calendar-x text-muted fs-1 mb-3"></i>
                                                <h5 class="text-muted">No recent appointments</h5>
                                                <p class="text-muted">When you have appointments, they'll appear here.</p>
                                                <a href="{{ path('app_scheduling_new') }}" class="btn btn-primary">
                                                    <i class="bi bi-plus-circle me-1"></i> Book Your First Appointment
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css">
{% endblock %}

{% block javascripts %}
{{ parent() }}
<!-- DataTables JS -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.colVis.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Refresh button functionality
        const refreshBtn = document.getElementById('refreshBtn');
        if (refreshBtn) {
            refreshBtn.addEventListener('click', function() {
                this.classList.add('rotate');
                setTimeout(() => {
                    window.location.reload();
                }, 500);
            });
        }

        // Initialize DataTable
        const appointmentsTable = $('#appointmentsTable').DataTable({
            dom: '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>' +
                 '<"row"<"col-sm-12"tr>>' +
                 '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
            language: {
                search: "Search appointments:",
                lengthMenu: "Show _MENU_ entries",
                info: "Showing _START_ to _END_ of _TOTAL_ appointments",
                infoEmpty: "No appointments available",
                infoFiltered: "(filtered from _MAX_ total appointments)",
                zeroRecords: "No matching appointments found",
                paginate: {
                    first: "First",
                    last: "Last",
                    next: "Next",
                    previous: "Previous"
                }
            },
            pageLength: 10,
            lengthMenu: [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
            order: [[1, 'desc']], // Sort by date (column 1) descending
            responsive: true,
            buttons: [
                {
                    extend: 'copy',
                    className: 'btn btn-outline-secondary btn-sm',
                    text: '<i class="bi bi-clipboard me-1"></i> Copy',
                    exportOptions: {
                        columns: ':visible'
                    }
                },
                {
                    extend: 'csv',
                    className: 'btn btn-outline-secondary btn-sm',
                    text: '<i class="bi bi-file-earmark-spreadsheet me-1"></i> CSV',
                    exportOptions: {
                        columns: ':visible'
                    }
                },
                {
                    extend: 'excel',
                    className: 'btn btn-outline-secondary btn-sm',
                    text: '<i class="bi bi-file-excel me-1"></i> Excel',
                    exportOptions: {
                        columns: ':visible'
                    }
                },
                {
                    extend: 'pdf',
                    className: 'btn btn-outline-secondary btn-sm',
                    text: '<i class="bi bi-file-pdf me-1"></i> PDF',
                    exportOptions: {
                        columns: ':visible'
                    }
                },
                {
                    extend: 'print',
                    className: 'btn btn-outline-secondary btn-sm',
                    text: '<i class="bi bi-printer me-1"></i> Print',
                    exportOptions: {
                        columns: ':visible'
                    }
                },
                {
                    extend: 'colvis',
                    className: 'btn btn-outline-secondary btn-sm',
                    text: '<i class="bi bi-columns-gap me-1"></i> Columns'
                }
            ],
            initComplete: function() {
                // Add export buttons
                this.api().buttons().container().appendTo('#appointmentsTable_wrapper .col-md-6:eq(0)');
                
                // Style search box
                $('.dataTables_filter input').addClass('form-control form-control-sm');
                $('.dataTables_filter input').attr('placeholder', 'Search appointments...');
                
                // Style length menu
                $('.dataTables_length select').addClass('form-select form-select-sm');
            },
            drawCallback: function() {
                // Reinitialize tooltips after table redraw
                const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                const tooltipList = tooltipTriggerList.map(function(tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl);
                });
                
                // Add hover effect to rows
                $('#appointmentsTable tbody tr').hover(
                    function() {
                        $(this).addClass('table-row-active');
                    },
                    function() {
                        $(this).removeClass('table-row-active');
                    }
                );
            }
        });

        // Custom search for status
        $('#statusFilter').on('change', function() {
            const status = $(this).val();
            if (status) {
                appointmentsTable.column(4).search(status, true, false).draw();
            } else {
                appointmentsTable.column(4).search('').draw();
            }
        });

        // Custom search for date range
        $('#dateFilter').on('change', function() {
            const dateRange = $(this).val();
            let searchTerm = '';
            
            switch(dateRange) {
                case 'today':
                    searchTerm = moment().format('YYYY-MM-DD');
                    break;
                case 'week':
                    searchTerm = moment().startOf('week').format('YYYY-MM-DD') + '|' + moment().endOf('week').format('YYYY-MM-DD');
                    break;
                case 'month':
                    searchTerm = moment().startOf('month').format('YYYY-MM-DD') + '|' + moment().endOf('month').format('YYYY-MM-DD');
                    break;
                default:
                    searchTerm = '';
            }
            
            appointmentsTable.column(1).search(searchTerm, true, false).draw();
        });

        // Add filter controls if needed
        const tableWrapper = $('#appointmentsTable_wrapper');
        const filterControls = `
            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="statusFilter" class="form-label small">Filter by Status</label>
                    <select id="statusFilter" class="form-select form-select-sm">
                        <option value="">All Statuses</option>
                        <option value="confirmed">Confirmed</option>
                        <option value="pending">Pending</option>
                        <option value="cancelled">Cancelled</option>
                        <option value="completed">Completed</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="dateFilter" class="form-label small">Filter by Date</label>
                    <select id="dateFilter" class="form-select form-select-sm">
                        <option value="">All Dates</option>
                        <option value="today">Today</option>
                        <option value="week">This Week</option>
                        <option value="month">This Month</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button id="clearFilters" class="btn btn-sm btn-outline-secondary w-100">
                        <i class="bi bi-x-circle me-1"></i> Clear Filters
                    </button>
                </div>
            </div>
        `;
        
        // Only add filters if there are appointments
        if (appointmentsTable.data().any()) {
            tableWrapper.find('.row:first').before(filterControls);
            
            // Clear filters button
            $('#clearFilters').on('click', function() {
                $('#statusFilter').val('');
                $('#dateFilter').val('');
                appointmentsTable.search('').columns().search('').draw();
            });
        }

        // Tooltip initialization
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));
    });
</script>
{% endblock %}