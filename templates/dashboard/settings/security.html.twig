{% extends 'dashboard/base.html.twig' %}

{% block title %}Security - Settings{% endblock %}

{% block dashboard_content %}
<div class="container py-4">
  
        
        <div class="col-md-9">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">Security Settings</h4>
                </div>
                <div class="card-body">
                    <!-- Current Session -->
                    <div class="mb-5">
                        <h5 class="mb-3">Current Session</h5>
                        <div class="card bg-light">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>IP Address:</strong> {{ app.request.clientIp }}</p>
                                        <p class="mb-1"><strong>Browser:</strong> {{ app.request.headers.get('User-Agent')|slice(0, 50) }}...</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Session Started:</strong> {{ 'now'|date('F j, Y \\a\\t g:i A') }}</p>
                                        <p class="mb-0"><strong>Device:</strong> 
                                            {% if 'mobile' in app.request.headers.get('User-Agent')|lower %}
                                                Mobile Device
                                            {% elseif 'tablet' in app.request.headers.get('User-Agent')|lower %}
                                                Tablet
                                            {% else %}
                                                Desktop Computer
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Login History -->
                    <div class="mb-5">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Recent Login Activity</h5>
                            <small class="text-muted">Showing last 10 logins</small>
                        </div>
                        
                        {% if login_history|length > 0 %}
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Date & Time</th>
                                            <th>IP Address</th>
                                            <th>Device</th>
                                            <th>Location</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for login in login_history %}
                                            <tr>
                                                <td>
                                                    {{ login.date }}
                                                    {% if loop.first %}
                                                        <span class="badge bg-success ms-1">Current</span>
                                                    {% endif %}
                                                </td>
                                                <td>{{ login.ip }}</td>
                                                <td>{{ login.device }}</td>
                                                <td>
                                                    {% if login.location is defined %}
                                                        {{ login.location }}
                                                    {% else %}
                                                        <span class="text-muted">Unknown</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                No login history available yet.
                            </div>
                        {% endif %}
                    </div>

                    <!-- Security Actions -->
                    <div class="mb-4">
                        <h5 class="mb-3">Security Actions</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-warning rounded-circle p-3 me-3">
                                                <i class="bi bi-key-fill text-white fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">Change Password</h6>
                                                <p class="text-muted mb-0 small">Update your password regularly</p>
                                            </div>
                                        </div>
                                        <p class="card-text">We recommend changing your password every 90 days for better security.</p>
                                        <a href="{{ path('app_settings_change_password') }}" class="btn btn-outline-warning">
                                            Change Password
                                        </a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-info rounded-circle p-3 me-3">
                                                <i class="bi bi-shield-check text-white fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">Two-Factor Authentication</h6>
                                                <p class="text-muted mb-0 small">Add an extra layer of security</p>
                                            </div>
                                        </div>
                                        <p class="card-text">Protect your account with two-factor authentication.</p>
                                        <button class="btn btn-outline-info" disabled>
                                            Coming Soon
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Account Security Tips -->
                    <div class="alert alert-warning">
                        <h6 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Security Tips</h6>
                        <ul class="mb-0">
                            <li>Use a strong, unique password that you don't use elsewhere</li>
                            <li>Never share your password or login credentials</li>
                            <li>Always log out when using public computers</li>
                            <li>Be cautious of phishing emails asking for your credentials</li>
                            <li>Regularly review your login activity for suspicious behavior</li>
                        </ul>
                    </div>

                    <!-- Sign out other sessions button -->
                    <div class="text-end">
                        <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#signOutModal">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign Out All Other Sessions
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sign Out Modal -->
<div class="modal fade" id="signOutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Sign Out Other Sessions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>This will sign you out of all devices except this one. You'll need to log in again on other devices.</p>
                <p class="text-muted small">Note: This feature is not yet implemented. It will be available in a future update.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" disabled>Sign Out Other Sessions</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// You can add JavaScript for security features here
document.addEventListener('DOMContentLoaded', function() {
    // Example: Show device details on click
    const deviceInfo = document.querySelectorAll('.device-info');
    deviceInfo.forEach(function(element) {
        element.addEventListener('click', function() {
            const device = this.dataset.device;
            const ip = this.dataset.ip;
            alert('Device: ' + device + '\nIP: ' + ip);
        });
    });
});
</script>
{% endblock %}