{% extends 'dashboard/base.html.twig' %}

{% block title %}Billing & Payments{% endblock %}

{% block dashboard_content %}  
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Billing & Payments</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_settings_index') }}">Settings</a></li>
                <li class="breadcrumb-item active">Billing</li>
            </ol>
        </nav>
    </div>
    <a href="{{ path('app_settings_index') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Settings
    </a>
</div>

<div class="row">
    <!-- Billing Overview -->
    <div class="col-lg-8">
        <!-- Payment Methods -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Payment Methods</h5>
                <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addPaymentModal">
                    <i class="bi bi-plus-circle me-1"></i> Add Payment Method
                </button>
            </div>
            <div class="card-body">
                {% if payment_methods|length > 0 %}
                    <div class="list-group">
                        {% for method in payment_methods %}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">
                                        {% if method.type == 'card' %}
                                            <i class="bi bi-credit-card me-2"></i>
                                        {% elseif method.type == 'paypal' %}
                                            <i class="bi bi-paypal me-2"></i>
                                        {% else %}
                                            <i class="bi bi-bank me-2"></i>
                                        {% endif %}
                                        {{ method.name }}
                                        {% if method.isDefault %}
                                            <span class="badge bg-primary ms-2">Default</span>
                                        {% endif %}
                                    </h6>
                                    <small class="text-muted">
                                        {% if method.type == 'card' %}
                                            **** **** **** {{ method.last4 }} • Expires {{ method.expiry }}
                                        {% elseif method.type == 'paypal' %}
                                            {{ method.email }}
                                        {% else %}
                                            {{ method.details }}
                                        {% endif %}
                                    </small>
                                </div>
                                <div class="btn-group">
                                    {% if not method.isDefault %}
                                    <button class="btn btn-sm btn-outline-primary" onclick="setDefaultPayment('{{ method.id }}')">
                                        Set Default
                                    </button>
                                    {% endif %}
                                    <button class="btn btn-sm btn-outline-danger" onclick="removePaymentMethod('{{ method.id }}')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-4">
                        <i class="bi bi-credit-card text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">No payment methods added</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Billing History -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Billing History</h5>
            </div>
            <div class="card-body">
                {% if invoices|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for invoice in invoices %}
                                <tr>
                                    <td>{{ invoice.date|date('Y-m-d') }}</td>
                                    <td>{{ invoice.description }}</td>
                                    <td>${{ invoice.amount|number_format(2) }}</td>
                                    <td>
                                        {% if invoice.status == 'paid' %}
                                            <span class="badge bg-success">Paid</span>
                                        {% elseif invoice.status == 'pending' %}
                                            <span class="badge bg-warning">Pending</span>
                                        {% else %}
                                            <span class="badge bg-danger">Failed</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="{{ invoice.download_url }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-download"></i> Invoice
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-4">
                        <i class="bi bi-receipt text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">No billing history available</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Billing Sidebar -->
    <div class="col-lg-4">
        <!-- Current Plan -->
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="card-title mb-0">Current Plan</h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div class="display-4 text-primary">${{ current_plan.price|number_format(2) }}</div>
                    <p class="text-muted">per {{ current_plan.interval }}</p>
                </div>
                <h5>{{ current_plan.name }}</h5>
                <ul class="list-unstyled">
                    {% for feature in current_plan.features %}
                    <li class="mb-2">
                        <i class="bi bi-check text-success me-2"></i>
                        {{ feature }}
                    </li>
                    {% endfor %}
                </ul>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#changePlanModal">
                        Change Plan
                    </button>
                    <button class="btn btn-outline-danger" onclick="cancelSubscription()">
                        Cancel Subscription
                    </button>
                </div>
            </div>
        </div>

        <!-- Billing Information -->
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="card-title mb-0">Billing Information</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Next Billing Date:</strong><br>
                    <span class="text-muted">{{ next_billing_date|date('F j, Y') }}</span>
                </div>
                <div class="mb-3">
                    <strong>Billing Cycle:</strong><br>
                    <span class="text-muted">{{ billing_cycle }}</span>
                </div>
                <div class="mb-0">
                    <strong>Auto-renew:</strong><br>
                    <span class="text-muted">{{ auto_renew ? 'Enabled' : 'Disabled' }}</span>
                </div>
            </div>
        </div>

        <!-- Tax Information -->
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">Tax Information</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Tax ID:</strong><br>
                    <span class="text-muted">{{ tax_id ?? 'Not set' }}</span>
                </div>
                <div class="mb-0">
                    <strong>Tax Rate:</strong><br>
                    <span class="text-muted">{{ tax_rate }}%</span>
                </div>
                <div class="mt-3">
                    <button class="btn btn-outline-secondary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#taxModal">
                        Update Tax Info
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Payment Method Modal -->
<div class="modal fade" id="addPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Payment Method</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" id="paymentTabs">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#cardTab">Credit Card</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#paypalTab">PayPal</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#bankTab">Bank Transfer</button>
                    </li>
                </ul>
                
                <div class="tab-content">
                    <!-- Credit Card Tab -->
                    <div class="tab-pane fade show active" id="cardTab">
                        <form id="cardForm">
                            <div class="mb-3">
                                <label class="form-label">Cardholder Name</label>
                                <input type="text" class="form-control" name="card_name" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Card Number</label>
                                <input type="text" class="form-control" name="card_number" placeholder="4242 4242 4242 4242" required>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Expiry Date</label>
                                    <input type="text" class="form-control" name="expiry" placeholder="MM/YY" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">CVV</label>
                                    <input type="text" class="form-control" name="cvv" required>
                                </div>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" name="set_default" id="setDefaultCard">
                                <label class="form-check-label" for="setDefaultCard">
                                    Set as default payment method
                                </label>
                            </div>
                        </form>
                    </div>
                    
                    <!-- PayPal Tab -->
                    <div class="tab-pane fade" id="paypalTab">
                        <form id="paypalForm">
                            <div class="mb-3">
                                <label class="form-label">PayPal Email</label>
                                <input type="email" class="form-control" name="paypal_email" required>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" name="set_default" id="setDefaultPayPal">
                                <label class="form-check-label" for="setDefaultPayPal">
                                    Set as default payment method
                                </label>
                            </div>
                        </form>
                    </div>
                    
                    <!-- Bank Transfer Tab -->
                    <div class="tab-pane fade" id="bankTab">
                        <form id="bankForm">
                            <div class="mb-3">
                                <label class="form-label">Account Holder Name</label>
                                <input type="text" class="form-control" name="account_name" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bank Name</label>
                                <input type="text" class="form-control" name="bank_name" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Account Number</label>
                                <input type="text" class="form-control" name="account_number" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Routing Number</label>
                                <input type="text" class="form-control" name="routing_number" required>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" name="set_default" id="setDefaultBank">
                                <label class="form-check-label" for="setDefaultBank">
                                    Set as default payment method
                                </label>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addPaymentMethod()">Add Payment Method</button>
            </div>
        </div>
    </div>
</div>

<!-- Change Plan Modal -->
<div class="modal fade" id="changePlanModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Change Subscription Plan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <div class="card border-primary h-100">
                            <div class="card-header bg-primary text-white text-center">
                                <h5 class="card-title mb-0">Basic</h5>
                                <div class="display-4 my-2">$29.99</div>
                                <small>per month</small>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled">
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> 1 Grooming Session</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> Basic Services</li>
                                    <li class="mb-2"><i class="bi bi-x text-danger me-2"></i> Premium Services</li>
                                </ul>
                            </div>
                            <div class="card-footer text-center">
                                <button class="btn btn-outline-primary w-100" onclick="selectPlan('basic')">
                                    Select Plan
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card border-warning h-100">
                            <div class="card-header bg-warning text-white text-center">
                                <h5 class="card-title mb-0">Premium</h5>
                                <div class="display-4 my-2">$49.99</div>
                                <small>per month</small>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled">
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> 2 Grooming Sessions</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> All Basic Services</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> Premium Services</li>
                                </ul>
                            </div>
                            <div class="card-footer text-center">
                                <button class="btn btn-outline-warning w-100" onclick="selectPlan('premium')">
                                    Select Plan
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card border-danger h-100">
                            <div class="card-header bg-danger text-white text-center">
                                <h5 class="card-title mb-0">Ultimate</h5>
                                <div class="display-4 my-2">$79.99</div>
                                <small>per month</small>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled">
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> 4 Grooming Sessions</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> All Services</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i> Priority Booking</li>
                                </ul>
                            </div>
                            <div class="card-footer text-center">
                                <button class="btn btn-outline-danger w-100" onclick="selectPlan('ultimate')">
                                    Select Plan
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tax Information Modal -->
<div class="modal fade" id="taxModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Tax Information</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="taxForm">
                    <div class="mb-3">
                        <label class="form-label">Tax ID / VAT Number</label>
                        <input type="text" class="form-control" name="tax_id" value="{{ tax_id ?? '' }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Company Name</label>
                        <input type="text" class="form-control" name="company_name">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tax Rate (%)</label>
                        <input type="number" class="form-control" name="tax_rate" step="0.01" value="{{ tax_rate }}">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="updateTaxInfo()">Save Changes</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function addPaymentMethod() {
            const activeTab = document.querySelector('#paymentTabs .nav-link.active');
            const tabId = activeTab.getAttribute('data-bs-target');
            let formId;
            
            if (tabId === '#cardTab') formId = 'cardForm';
            else if (tabId === '#paypalTab') formId = 'paypalForm';
            else if (tabId === '#bankTab') formId = 'bankForm';
            
            const form = document.getElementById(formId);
            const formData = new FormData(form);
            
            fetch('/dashboard/settings/add-payment-method', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-CSRF-Token': '{{ csrf_token("add_payment") }}'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Payment method added successfully!');
                    $('#addPaymentModal').modal('hide');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
        
        function setDefaultPayment(methodId) {
            if (confirm('Set this as your default payment method?')) {
                fetch('/dashboard/settings/set-default-payment/' + methodId, {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ csrf_token("set_default_payment") }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
        
        function removePaymentMethod(methodId) {
            if (confirm('Remove this payment method?')) {
                fetch('/dashboard/settings/remove-payment-method/' + methodId, {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ csrf_token("remove_payment") }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
        
        function selectPlan(plan) {
            if (confirm('Change to ' + plan + ' plan?')) {
                fetch('/dashboard/settings/change-plan', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': '{{ csrf_token("change_plan") }}'
                    },
                    body: JSON.stringify({ plan: plan })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Plan changed successfully!');
                        $('#changePlanModal').modal('hide');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                });
            }
        }
        
        function cancelSubscription() {
            if (confirm('Are you sure you want to cancel your subscription?')) {
                fetch('/dashboard/settings/cancel-subscription', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ csrf_token("cancel_subscription") }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Subscription cancelled successfully!');
                        location.reload();
                    }
                });
            }
        }
        
        function updateTaxInfo() {
            const form = document.getElementById('taxForm');
            const formData = new FormData(form);
            
            fetch('/dashboard/settings/update-tax-info', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-CSRF-Token': '{{ csrf_token("update_tax") }}'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Tax information updated!');
                    $('#taxModal').modal('hide');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
    </script>
{% endblock %}