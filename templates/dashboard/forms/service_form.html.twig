{% extends 'dashboard/base.html.twig' %}

{% from 'dashboard/components/form_layout.html.twig' import form_header, form_actions %}

{% block title %}{{ service.id ? 'Edit' : 'New' }} Service - Dashboard{% endblock %}

{% block dashboard_content %}  
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                {{ form_header(
                    (service.id ? 'Edit Service' : 'Create New Service'),
                    (service.id ? 'Update service details' : 'Add a new service to your offerings')
                ) }}
                
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    
                    <div class="row">
                        <div class="col-md-8">
                            {{ form_row(form.name) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.category) }}
                        </div>
                    </div>
                    
                    {{ form_row(form.description) }}
                    
                    <div class="row">
                        <div class="col-md-4">
                            {{ form_row(form.price) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.duration) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.weightLimit) }}
                        </div>
                    </div>
                    
                    {{ form_row(form.features) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.minPetAge) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.maxPetAge) }}
                        </div>
                    </div>
                    
                    {{ form_row(form.specialInstructions) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.image) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.requiresSpecialEquipment) }}
                            {{ form_row(form.isActive) }}
                        </div>
                    </div>
                    
                    {{ form_actions(
                        'app_service_delete',
                        service.id,
                        service.id
                    ) }}
                    
                    {{ form_end(form) }}
                </div>
            </div>
            
            {% if service.id and service.image %}
            <div class="card mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Service Image Preview</h5>
                </div>
                <div class="card-body text-center">
                    <img src="{{ service.image }}" alt="{{ service.name }}" 
                         class="img-fluid rounded" style="max-height: 200px;">
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}