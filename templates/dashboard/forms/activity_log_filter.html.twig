{# This is a partial template for filtering activity logs #}
<div class="card mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">Filter Logs</h5>
    </div>
    <div class="card-body">
        {{ form_start(filterForm, {
            'attr': {'class': 'row g-3', 'id': 'activity-log-filter-form'}
        }) }}
        
        <div class="col-md-3">
            {{ form_row(filterForm.user) }}
        </div>
        
        <div class="col-md-3">
            {{ form_row(filterForm.action) }}
        </div>
        
        <div class="col-md-3">
            {{ form_row(filterForm.startDate) }}
        </div>
        
        <div class="col-md-3">
            {{ form_row(filterForm.endDate) }}
        </div>
        
        <div class="col-md-3">
            {{ form_row(filterForm.sortBy) }}
        </div>
        
        <div class="col-12">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-filter me-1"></i>Apply Filters
                </button>
                <a href="{{ path('app_activity_log_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>Clear Filters
                </a>
                <a href="{{ path('app_activity_log_export', app.request.query.all) }}" class="btn btn-outline-success ms-auto">
                    <i class="bi bi-download me-1"></i>Export
                </a>
            </div>
        </div>
        
        {{ form_end(filterForm) }}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Auto-submit form when filter values change
    const filterForm = document.getElementById('activity-log-filter-form');
    const filterInputs = filterForm.querySelectorAll('select, input');
    
    filterInputs.forEach(input => {
        input.addEventListener('change', function() {
            filterForm.submit();
        });
    });
    
    // Date pickers
    const datePickers = document.querySelectorAll('.datepicker');
    datePickers.forEach(picker => {
        // Initialize date picker
        // Example with Flatpickr:
        // flatpickr(picker, {
        //     dateFormat: "Y-m-d",
        // });
    });
});
</script>+