{% extends 'dashboard/base.html.twig' %}

{% from 'dashboard/components/form_layout.html.twig' import form_header, form_actions %}

{% block title %}Change Password - Dashboard{% endblock %}

{% block dashboard_content %}  
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card">
                {{ form_header('Change Password', 'Update your account password') }}
                
                <div class="card-body">
                    {% if app.session.flashbag.peek('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            {{ app.session.flashbag.get('error')[0] }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}
                    
                    <div class="alert alert-info">
                        <i class="bi bi-shield-check me-2"></i>
                        Your password must be at least 8 characters long and contain a mix of letters, numbers, and symbols.
                    </div>
                    
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    
                    {{ form_row(form.currentPassword) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.newPassword.first) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.newPassword.second) }}
                        </div>
                    </div>
                    
                    <div class="progress mb-3" style="height: 5px;">
                        <div class="progress-bar" id="password-strength-bar" role="progressbar" style="width: 0%"></div>
                    </div>
                    <small class="text-muted" id="password-strength-text">Password strength: Very weak</small>
                    
                    {{ form_actions() }}
                    
                    {{ form_end(form) }}
                </div>
            </div>
            
            <div class="card mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Password Requirements</h5>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li>At least 8 characters long</li>
                        <li>Contains uppercase and lowercase letters</li>
                        <li>Includes numbers (0-9)</li>
                        <li>Contains special characters (!@#$%^&*)</li>
                        <li>Not similar to your username or email</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const newPasswordInput = document.querySelector('input[name="change_password_form[newPassword][first]"]');
    const strengthBar = document.getElementById('password-strength-bar');
    const strengthText = document.getElementById('password-strength-text');
    
    if (newPasswordInput && strengthBar && strengthText) {
        newPasswordInput.addEventListener('input', function() {
            const password = this.value;
            const strength = checkPasswordStrength(password);
            
            strengthBar.style.width = strength.percentage + '%';
            strengthBar.className = 'progress-bar ' + strength.class;
            strengthText.textContent = 'Password strength: ' + strength.text;
            strengthText.className = strength.textClass;
        });
    }
    
    function checkPasswordStrength(password) {
        let score = 0;
        
        // Length check
        if (password.length >= 8) score += 20;
        if (password.length >= 12) score += 20;
        
        // Character variety checks
        if (/[a-z]/.test(password)) score += 10;
        if (/[A-Z]/.test(password)) score += 10;
        if (/[0-9]/.test(password)) score += 10;
        if (/[^a-zA-Z0-9]/.test(password)) score += 10;
        
        // Bonus points
        if (password.length >= 16) score += 20;
        
        // Cap at 100
        score = Math.min(score, 100);
        
        // Determine strength level
        if (score <= 20) {
            return {
                percentage: score,
                text: 'Very Weak',
                class: 'bg-danger',
                textClass: 'text-danger'
            };
        } else if (score <= 40) {
            return {
                percentage: score,
                text: 'Weak',
                class: 'bg-danger',
                textClass: 'text-danger'
            };
        } else if (score <= 60) {
            return {
                percentage: score,
                text: 'Fair',
                class: 'bg-warning',
                textClass: 'text-warning'
            };
        } else if (score <= 80) {
            return {
                percentage: score,
                text: 'Good',
                class: 'bg-info',
                textClass: 'text-info'
            };
        } else {
            return {
                percentage: score,
                text: 'Strong',
                class: 'bg-success',
                textClass: 'text-success'
            };
        }
    }
});
</script>
{% endblock %}