{% extends 'dashboard/base.html.twig' %}

{% block title %}Subscription Details - #{{ subscription.id }}{% endblock %}
{% block dashboard_content %}  
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Subscription Details</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_subscription_index') }}">Subscriptions</a></li>
                <li class="breadcrumb-item active">#{{ subscription.id }}</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="{{ path('app_subscription_edit', {'id': subscription.id}) }}" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a href="{{ path('app_subscription_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <!-- Subscription Details -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Subscription Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>Subscription ID:</strong><br>
                        <span class="text-muted">#{{ subscription.id }}</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Status:</strong><br>
                        {% if subscription.status == 'active' %}
                            <span class="badge bg-success">Active</span>
                        {% else %}
                            <span class="badge bg-danger">Inactive</span>
                        {% endif %}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>Plan:</strong><br>
                        <span class="badge bg-{{ subscription.plan == 'Premium' ? 'warning' : subscription.plan == 'Ultimate' ? 'danger' : 'primary' }}">
                            {{ subscription.plan }}
                        </span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Amount:</strong><br>
                        <span class="text-muted">${{ subscription.amount|number_format(2) }} per month</span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <strong>Start Date:</strong><br>
                        <span class="text-muted">{{ subscription.startDate|date('F j, Y') }}</span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <strong>End Date:</strong><br>
                        <span class="text-muted">
                            {% if subscription.endDate %}
                                {{ subscription.endDate|date('F j, Y') }}
                            {% else %}
                                Auto-renew
                            {% endif %}
                        </span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <strong>Renewal Date:</strong><br>
                        <span class="text-muted">
                            {% if subscription.renewalDate %}
                                {{ subscription.renewalDate|date('F j, Y') }}
                            {% else %}
                                N/A
                            {% endif %}
                        </span>
                    </div>
                </div>

                {% if subscription.stripeCustomerId %}
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>Stripe Customer ID:</strong><br>
                        <span class="text-muted">{{ subscription.stripeCustomerId }}</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Stripe Subscription ID:</strong><br>
                        <span class="text-muted">{{ subscription.stripeSubscriptionId }}</span>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Customer Information -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Customer Information</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    {% if subscription.user.userProfile and subscription.user.userProfile.photo %}
                        <img src="{{ subscription.user.userProfile.photo }}" alt="{{ subscription.user.username }}" class="rounded-circle me-3" style="width: 80px; height: 80px;">
                    {% else %}
                        <div class="avatar bg-secondary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person text-white" style="font-size: 2.5rem;"></i>
                        </div>
                    {% endif %}
                    <div>
                        <h4 class="mb-0">{{ subscription.user.displayName }}</h4>
                        <p class="text-muted mb-1">{{ subscription.user.email }}</p>
                        <p class="mb-0">
                            <small class="text-muted">Customer since {{ subscription.user.createdAt|date('M Y') }}</small>
                        </p>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td width="40%">Phone:</td>
                                <td>{{ subscription.user.userProfile.phoneNumber ?? 'N/A' }}</td>
                            </tr>
                            <tr>
                                <td>Total Pets:</td>
                                <td>{{ customer_pets }}</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td width="40%">Account Status:</td>
                                <td>
                                    {% if subscription.user.isActive %}
                                        <span class="badge bg-success">Active</span>
                                    {% else %}
                                        <span class="badge bg-danger">Inactive</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td>Verified:</td>
                                <td>
                                    {% if subscription.user.isVerified %}
                                        <span class="badge bg-success">Yes</span>
                                    {% else %}
                                        <span class="badge bg-warning">No</span>
                                    {% endif %}
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Payment & Billing -->
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="card-title mb-0">Payment & Billing</h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="display-4 text-primary">${{ subscription.amount|number_format(2) }}</div>
                    <p class="text-muted">Monthly Subscription</p>
                </div>
                
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Next Payment:</span>
                        <strong>
                            {% if subscription.renewalDate %}
                                {{ subscription.renewalDate|date('M d, Y') }}
                            {% else %}
                                N/A
                            {% endif %}
                        </strong>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Billing Cycle:</span>
                        <strong>Monthly</strong>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Payment Method:</span>
                        <strong>Credit Card</strong>
                    </div>
                </div>
                
                <div class="d-grid gap-2 mt-3">
                    {% if subscription.status == 'active' %}
                        <button class="btn btn-outline-danger" onclick="cancelSubscription({{ subscription.id }})">
                            <i class="bi bi-x-circle me-2"></i> Cancel Subscription
                        </button>
                    {% else %}
                        <button class="btn btn-outline-success" onclick="activateSubscription({{ subscription.id }})">
                            <i class="bi bi-check-circle me-2"></i> Activate Subscription
                        </button>
                    {% endif %}
                    <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#paymentModal">
                        <i class="bi bi-credit-card me-2"></i> Process Payment
                    </button>
                </div>
            </div>
        </div>

        <!-- Subscription History -->
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="card-title mb-0">Subscription History</h6>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <small class="text-muted">{{ subscription.createdAt|date('M d, Y') }}</small>
                            <p class="mb-0">Subscription created</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <small class="text-muted">{{ subscription.startDate|date('M d, Y') }}</small>
                            <p class="mb-0">Subscription started</p>
                        </div>
                    </div>
                    {% if subscription.updatedAt %}
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <small class="text-muted">{{ subscription.updatedAt|date('M d, Y') }}</small>
                            <p class="mb-0">Last updated</p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_subscription_edit', {'id': subscription.id}) }}" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-2"></i> Edit Subscription
                    </a>
                    <a href="{{ path('app_scheduling_new', {'user_id': subscription.user.id}) }}" class="btn btn-outline-success">
                        <i class="bi bi-calendar-plus me-2"></i> Schedule Appointment
                    </a>
                    <button class="btn btn-outline-info" onclick="sendInvoice({{ subscription.id }})">
                        <i class="bi bi-receipt me-2"></i> Send Invoice
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Process Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="paymentForm">
                    <div class="mb-3">
                        <label class="form-label">Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" name="amount" value="{{ subscription.amount }}" step="0.01" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Method</label>
                        <select class="form-select" name="payment_method" required>
                            <option value="credit_card">Credit Card</option>
                            <option value="debit_card">Debit Card</option>
                            <option value="bank_transfer">Bank Transfer</option>
                            <option value="cash">Cash</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Date</label>
                        <input type="date" class="form-control" name="payment_date" value="{{ "now"|date("Y-m-d") }}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes (Optional)</label>
                        <textarea class="form-control" name="notes" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="processPayment({{ subscription.id }})">Process Payment</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function cancelSubscription(subscriptionId) {
            if (confirm('Are you sure you want to cancel this subscription?')) {
                fetch('/dashboard/subscription/' + subscriptionId + '/cancel', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ csrf_token("cancel_subscription") }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
        
        function activateSubscription(subscriptionId) {
            if (confirm('Activate this subscription?')) {
                fetch('/dashboard/subscription/' + subscriptionId + '/activate', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ csrf_token("activate_subscription") }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
        
        function processPayment(subscriptionId) {
            const form = document.getElementById('paymentForm');
            const formData = new FormData(form);
            
            fetch('/dashboard/subscription/' + subscriptionId + '/process-payment', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-CSRF-Token': '{{ csrf_token("process_payment") }}'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Payment processed successfully!');
                    $('#paymentModal').modal('hide');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
        
        function sendInvoice(subscriptionId) {
            if (confirm('Send invoice to customer?')) {
                fetch('/dashboard/subscription/' + subscriptionId + '/send-invoice', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ csrf_token("send_invoice") }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Invoice sent successfully!');
                    }
                });
            }
        }
    </script>
    <style>
        .timeline {
            position: relative;
            padding-left: 20px;
        }
        .timeline-item {
            position: relative;
            margin-bottom: 15px;
        }
        .timeline-marker {
            position: absolute;
            left: -20px;
            top: 5px;
            width: 10px;
            height: 10px;
            background: #6c757d;
            border-radius: 50%;
        }
        .timeline-content {
            padding-left: 5px;
        }
    </style>
{% endblock %}