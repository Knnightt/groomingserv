                        </li>
                        <li class="mb-2">
                            <i class="bi bi-envelope me-2"></i>
                            <a href="mailto:contact@quibotgrooming.com">contact@quibotgrooming.com</a>
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-telephone me-2"></i>
                            <a href="tel:+639123456789">+63 912 345 6789</a>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h5>Newsletter</h5>
