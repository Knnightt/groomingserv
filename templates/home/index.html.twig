                    <a href="/login" class="btn btn-outline-primary btn-sm me-lg-2 mb-2 mb-lg-0">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="/register" class="btn btn-warning btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Sign Up
                    </a>
                </div>
            </div>
        </div>
    </nav>
    <!-- Header & Hero Section -->
