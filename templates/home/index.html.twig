                        <p class="text-muted">Gentle handling for anxious pets</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center p-4">
                        <div class="service-icon">
                            <i class="bi bi-clipboard-check"></i>
                        </div>
                        <h4>Health Check</h4>
                        <p class="text-muted">Basic health assessment during grooming</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Vision Section -->
    <section class="vision-section">
        <div class="container">
            <div class="row mb-5">
                <div class="col-lg-8 mx-auto text-center">
                    <h2 class="display-5 mb-3">Our Vision</h2>
                    <p class="lead">A trusted and innovative pet grooming hub where every pet experiences gentle care, and every pet owner enjoys peace of mind.</p>
                </div>
            </div>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="vision-point">
                        <div class="vision-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h3>Trusted Hands</h3>
                        <p>Professional staff dedicated to pet wellness with years of experience and compassion.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="vision-point">
                        <div class="vision-icon">
                            <i class="bi bi-lightbulb"></i>
                        </div>
                        <h3>Innovative Care</h3>
                        <p>Modern techniques and equipment for better comfort and results.</p>
                    </div>
                </div>
