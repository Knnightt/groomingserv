                </div>
            </div>
            <div class="row g-4">
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center p-4">
                        <div class="service-icon">
                            <i class="bi bi-scissors"></i>
                        </div>
                        <h4>Full Grooming</h4>
                        <p class="text-muted">Complete grooming package from head to tail</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center p-4">
                        <div class="service-icon">
                            <i class="bi bi-droplet"></i>
                        </div>
                        <h4>Spa & Bath</h4>
                        <p class="text-muted">Luxurious spa treatments for your pet</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center p-4">
                        <div class="service-icon">
                            <i class="bi bi-heart"></i>
                        </div>
