                    </div>
                </div>
                
                <!-- Premium Spa -->
                <div class="col-lg-4">
                    <div class="pricing-card p-4 text-center featured">
                        <span class="badge bg-warning text-dark position-absolute top-0 start-50 translate-middle p-2">Most Popular</span>
                        <h3 class="mb-3">Premium Spa</h3>
                        <div class="price-tag mb-3">₱ 5,000</div>
                        <p class="text-muted mb-4">Our signature spa experience for ultimate relaxation</p>
                        <ul class="list-unstyled mb-4">
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Everything in Essential</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Deep conditioning treatment</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Pawdicure & massage</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>De-shedding treatment</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Fur fragrance</li>
                        </ul>
                        <a href="#booking" class="btn btn-primary w-100">Book Now</a>
                    </div>
                </div>
                
                <!-- Ultimate Pamper -->
                <div class="col-lg-4">
                    <div class="pricing-card p-4 text-center">
                        <h3 class="mb-3">Ultimate Pamper</h3>
                        <div class="price-tag mb-3">₱ 10,000</div>
                        <p class="text-muted mb-4">The ultimate luxury experience for your beloved pet</p>
                        <ul class="list-unstyled mb-4">
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Everything in Premium Spa</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Blueberry facial</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Hot oil treatment</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Teeth brushing</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Gland expression</li>
                            <li class="pricing-feature"><i class="bi bi-check-circle text-success me-2"></i>Take-home gift package</li>
                        </ul>
                        <a href="#booking" class="btn btn-outline-primary w-100">Book Now</a>
