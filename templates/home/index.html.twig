                        <a href="#booking" class="btn btn-secondary btn-lg me-3">
                            <i class="bi bi-calendar-check me-2"></i>Book Appointment
                        </a>
                        <a href="#contact" class="btn btn-outline-light btn-lg">
                            <i class="bi bi-telephone me-2"></i>Contact Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
