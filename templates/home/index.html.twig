                    <p class="lead mb-4">Experience the Quibot's Grooming difference. Book an appointment and let us provide the comfort and style your pet deserves.</p>
                    <div class="mt-4">
                        <a href="tel:+639123456789" class="btn btn-light btn-lg me-3">
                            <i class="bi bi-telephone me-2"></i>Call Now
                        </a>
                        <a href="mailto:contact@grooming.com" class="btn btn-outline-light btn-lg">
                            <i class="bi bi-envelope me-2"></i>Email Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
