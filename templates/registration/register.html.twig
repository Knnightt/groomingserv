{% extends 'base.html.twig' %}

{% block title %}Register - Quibot's Grooming{% endblock %}

{% block auth_css %}
    <link href="{{ asset('css/auth.css') }}" rel="stylesheet">
{% endblock %}

{% block navigation %}{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="auth-card">
                    <div class="row g-0">
                        <!-- Left Side - Welcome Message -->
                        <div class="col-lg-6 d-none d-lg-block">
                            <div class="auth-left">
                                <h2>Join our community!</h2>
                                <p>Create an account to book appointments, manage your pets, and get exclusive offers.</p>
                                
                                <div class="testimonial">
                                    <p>"Quibot Grooming services has transformed how I care for my pets. The booking is seamless and the staff is incredible."</p>
                                    <div class="testimonial-author">
                                        <div class="author-avatar">K</div>
                                        <div class="author-info">
                                            <strong>Ken Quibot</strong>
                                            <span class="small">Long-time Customer</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Right Side - Registration Form -->
                        <div class="col-lg-6">
                            <div class="auth-right">
                                <div class="auth-header">
                                    <h1>Create an account</h1>
                                    <p>Join us to pamper your furry friends</p>
                                </div>
                                
                                <div class="auth-form">
                                    {{ form_start(registrationForm, {
                                        'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}
                                    }) }}
                                        
                                        {{ form_row(registrationForm.email) }}
                                        {{ form_row(registrationForm.username) }}
                                        {{ form_row(registrationForm.fullName) }}
                                        
                                        <div class="row">
                                            <div class="col-md-6">
                                                {{ form_row(registrationForm.plainPassword.first) }}
                                            </div>
                                            <div class="col-md-6">
                                                {{ form_row(registrationForm.plainPassword.second) }}
                                            </div>
                                        </div>
                                        
                                        <div class="form-check mb-4">
                                            {{ form_row(registrationForm.agreeTerms) }}
                                        </div>
                                        
                                        <div class="d-grid gap-2">
                                            <button class="btn btn-primary btn-lg" type="submit">
                                                Create Account
                                            </button>
                                        </div>
                                        
                                    {{ form_end(registrationForm) }}
                                    
                                    <div class="auth-divider">
                                        <span>OR CONTINUE WITH</span>
                                    </div>
                                    
                                    <div class="social-login">
                                        <a href="#" class="social-btn google">
                                            <i class="bi bi-google"></i>
                                            <span>Google</span>
                                        </a>
                                        <a href="#" class="social-btn facebook">
                                            <i class="bi bi-facebook"></i>
                                            <span>Facebook</span>
                                        </a>
                                    </div>
                                    
                                    <div class="auth-footer">
                                        Already have an account? 
                                        <a href="{{ path('app_login') }}">Sign in</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block auth_js %}
    <script src="{{ asset('js/auth.js') }}"></script>
{% endblock %}